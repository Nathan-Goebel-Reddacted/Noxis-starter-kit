# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Persistent game data (players, game definitions, history...)
POSTGRES_USER=cardgame
POSTGRES_PASSWORD=change_me
POSTGRES_DB=cardgame
POSTGRES_PORT=5432
DATABASE_URL=postgresql://cardgame:change_me@localhost:5432/cardgame

# ─── Redis ────────────────────────────────────────────────────────────────────
# In-progress game instances (volatile state, sessions, pub/sub)
REDIS_PASSWORD=change_me
REDIS_PORT=6379
REDIS_URL=redis://:change_me@localhost:6379

# ─── API Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000
