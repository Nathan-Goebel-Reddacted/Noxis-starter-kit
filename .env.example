# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Persistent data
MONGO_USER=app
MONGO_PASSWORD=change_me
MONGO_DB=app
MONGO_PORT=27017
DATABASE_URL=mongodb://app:change_me@localhost:27017/app?authSource=admin

# ─── Redis ────────────────────────────────────────────────────────────────────
# Volatile state, sessions, pub/sub
# Provided by docker-compose but not wired in code: no client, no adapter.
# Remove it entirely if the project has no use for it.
REDIS_PASSWORD=change_me
REDIS_PORT=6379
REDIS_URL=redis://:change_me@localhost:6379

# ─── API Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000

# ─── Docker (profil `app` uniquement) ─────────────────────────────────────────
# Port exposé par le conteneur nginx servant le front
WEB_PORT=8080
