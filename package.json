{
  "name": "app-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc -p apps/Shared && tsc -p apps/Bun && tsc -p apps/React",
    "lint": "bun run typecheck && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:bun": "bun run --filter '@app/bun' dev",
    "dev:react": "bun run --filter '@app/react' dev",
    "build": "bun run --filter '*' build",
    "migrate": "bun run --filter '@app/bun' migrate",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "lefthook": "^1.6.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
